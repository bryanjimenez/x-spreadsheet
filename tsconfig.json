{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./.tsc-dist/",

    "skipLibCheck": true,

    "allowSyntheticDefaultImports": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "allowJs": true,
    "checkJs": true,

    "removeComments": true,
    "declaration": true,

    "noImplicitReturns": true,
  },
  "exclude": ["./node_modules", "./dist"],
  "include": ["./src", "./test"]
}
