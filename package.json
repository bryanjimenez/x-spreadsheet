{
  "name": "@nmemonica/x-spreadsheet",
  "version": "0.1.8-alpha.0",
  "description": "A Typescript xpreadsheet",
  "type": "module",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./helper": {
      "default": "./dist/helper.js",
      "types": "./dist/types/helper.d.ts"
    },
    "./types/*": "./dist/types/*.d.ts",
    "./locale/*": {
      "default": "./dist/locale/*.json",
      "types": "./dist/types/locale/*.d.ts"
    },
    "./index.css": "./dist/index.css"
  },
  "types": "dist/types/index.d.ts",
  "files": [
    "assets",
    "dist",
    "THIRD_PARTY_LICENSE"
  ],
  "author": "bryan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bryanjimenez/x-spreadsheet.git"
  },
  "scripts": {
    "dev": "rspack serve -c ./build/rspack.dev.js",
    "prebuild": "rm -rf ./dist",
    "build": "rspack build -c ./build/rspack.prod.js",
    "postbuild": "npm run build-dts",
    "build-dts": "tsc -p ./tsconfig.types.json | cat",
    "test": "mocha -r ./test/require.mjs --recursive --extension ts ./test",
    "coverage": "nyc npm run test > '/dev/null'; nyc report",
    "type": "tsc -b",
    "staged": "git diff --staged --diff-filter=d --name-only",
    "lint": "npm run -s staged | xargs eslint --fix",
    "lint:all": "DEBUG=*,-@hwc*,-eslint:code-path eslint ."
  },
  "keywords": [
    "javascript",
    "spreadsheet",
    "canvas"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@rspack/cli": "^1.7.6",
    "@rspack/core": "^1.7.6",
    "@types/md5": "^2.3.5",
    "@types/mocha": "^10.0.6",
    "@typescript-eslint/parser": "^8.54.0",
    "canvas": "^3.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom-global": "^3.0.2",
    "less-loader": "^12.3.1",
    "license-checker-webpack-plugin": "^0.2.1",
    "mocha": "^11.6.0",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.1",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  }
}
